<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.academicpulse.desktop.controllers.TopicThreadsController">
    <left>
        <fx:include source="sidebar.fxml"/>
    </left>
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Button text="&#8592; Back" onAction="#handleBack"/>
            <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="8" right="16" bottom="16" left="16"/>
            </padding>
            <Label fx:id="statusLabel" style="-fx-text-fill: #7182a8;"/>
            <ListView fx:id="threadsListView" VBox.vgrow="ALWAYS"/>
            <Button text="Open Thread" onAction="#handleOpenThread" maxWidth="Infinity"/>
        </VBox>
    </center>
    <bottom>
        <VBox spacing="8">
            <padding>
                <Insets top="8" right="16" bottom="16" left="16"/>
            </padding>
            <Label text="Ask a question" style="-fx-font-weight: bold;"/>
            <TextField fx:id="questionTitleField" promptText="Question title"/>
            <TextArea fx:id="questionBodyField" promptText="Describe your question..." prefRowCount="3"/>
            <Button text="Ask" onAction="#handleAsk" maxWidth="Infinity"/>
        </VBox>
    </bottom>
</BorderPane>
