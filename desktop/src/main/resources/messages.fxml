<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.academicpulse.desktop.controllers.MessagesController">
    <left>
        <fx:include source="sidebar.fxml"/>
    </left>
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Messages" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="New Message" onAction="#handleNewMessage"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="8" right="16" bottom="16" left="16"/>
            </padding>
            <Label fx:id="statusLabel" style="-fx-text-fill: #7182a8;"/>
            <ListView fx:id="conversationsListView" VBox.vgrow="ALWAYS"/>
            <Button text="Open Conversation" onAction="#handleOpenConversation" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>
